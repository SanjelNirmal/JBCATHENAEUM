{
  "name": "jbcathenaeum-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace frontend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "build": "npm run build --workspace frontend && rm -rf dist && cp -r frontend/dist dist",
    "verify:deployment": "node frontend/scripts/verify-deployment-assets.mjs",
    "lint": "npm run lint --workspace frontend && npm run lint --workspace backend",
    "start": "npm run start --workspace backend",
    "test": "npm run test --workspace frontend && npm run test --workspace backend"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3"
  },
  "dependencies": {
    "@capacitor/ios": "^8.4.2",
    "lucide-react": "^1.25.0",
    "motion": "^12.42.2",
    "react-router-dom": "^7.18.1"
  }
}

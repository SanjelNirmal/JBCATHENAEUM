{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:native": "vite build --mode native",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:public": "playwright test e2e/public.spec.ts",
    "cap:sync": "npm run build:native && cap sync",
    "cap:android": "npm run build:native && cap sync android && cap open android",
    "cap:ios": "npm run build:native && cap sync ios && cap open ios",
    "cap:copy": "npm run build:native && cap copy",
    "cap:update": "cap update"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/browser": "^8.0.4",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/share": "^8.0.1",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.101.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.42.2",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@capacitor/cli": "^8.4.2",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6"
  }
}
